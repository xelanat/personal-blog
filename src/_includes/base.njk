<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}{{ meta.title }}</title>
  <meta name="description" content="{{ description or meta.description }}" />
  <script>
    (() => {
      const preferredTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      let nextTheme = preferredTheme;
      try {
        const storedTheme = localStorage.getItem("theme");
        if (storedTheme === "light" || storedTheme === "dark") {
          nextTheme = storedTheme;
        }
      } catch (_) {}
      document.documentElement.dataset.theme = nextTheme;
    })();
  </script>
  <link rel="stylesheet" href="/assets/css/style.css" />
</head>
<body class="font-sans bg-gray-50 text-gray-900 leading-relaxed flex flex-col min-h-screen">
  <header class="border-b border-gray-200 bg-white sticky top-0 z-10">
    <nav class="max-w-2xl mx-auto px-6 py-4 flex items-center justify-between">
      <a class="font-bold text-lg text-gray-900 hover:no-underline" href="/">{{ meta.title }}</a>
      
      <div class="flex items-center gap-6">
        <div class="flex items-center">
          <ul class="flex gap-2 list-none">
            <li><a class="text-sm text-gray-500 hover:text-blue-600" href="/blog/">Blog</a></li>
          </ul>
        </div>
        <div class="flex items-center justify-center gap-1">
          <button
            id="theme-toggle"
            type="button"
            class="text-gray-500 border border-gray-200 rounded px-2 py-1.5 hover:text-blue-600 inline-flex items-center justify-center"
            aria-label="Toggle color theme"
            aria-pressed="false"
          >
            <svg id="theme-icon-sun" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"/>
            </svg>
            <svg id="theme-icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3c0 .28 0 .57.02.85A7 7 0 0 0 20.15 12c.28.02.57.02.85.02Z"/>
            </svg>
            <span class="sr-only" id="theme-toggle-label">Toggle color theme</span>
          </button>
          <a
            class="text-blue-600 hover:text-blue-700 inline-flex items-center rounded-md p-1.5 hover:bg-blue-100 focus-visible:outline-none focus-visible:bg-blue-100 transition-colors"
            href="mailto:{{ meta.email }}"
            aria-label="Email"
            title="Email"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="M3 7l9 6 9-6"></path>
            </svg>
          </a>
          <a
            class="text-blue-600 hover:text-blue-700 inline-flex items-center rounded-md p-1.5 hover:bg-blue-100 focus-visible:outline-none focus-visible:bg-blue-100 transition-colors"
            href="https://github.com/xelanat"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
            title="GitHub"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.58 2 12.24c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-1.03-.01-1.87-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.93.86.09-.67.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05A9.3 9.3 0 0 1 12 6.84c.85 0 1.7.12 2.5.36 1.9-1.32 2.74-1.05 2.74-1.05.56 1.4.21 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.07.36.32.67.94.67 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.6.69.49A10.24 10.24 0 0 0 22 12.24C22 6.58 17.52 2 12 2z"></path>
            </svg>
          </a>
        </div>
      </div>
    </nav>
  </header>

  <main class="max-w-2xl mx-auto px-6 py-12 flex-1 w-full">
    {{ content | safe }}
  </main>

  <script>
    (() => {
      const toggleButton = document.getElementById("theme-toggle");
      const moonIcon = document.getElementById("theme-icon-moon");
      const sunIcon = document.getElementById("theme-icon-sun");
      if (!toggleButton || !moonIcon || !sunIcon) return;

      const persistTheme = (theme) => {
        try {
          localStorage.setItem("theme", theme);
        } catch (_) {}
      };

      const updateToggleState = () => {
        const isDark = document.documentElement.dataset.theme === "dark";
        toggleButton.setAttribute("aria-pressed", String(isDark));
        toggleButton.setAttribute("aria-label", isDark ? "Switch to light theme" : "Switch to dark theme");
        moonIcon.classList.toggle("hidden", isDark);
        sunIcon.classList.toggle("hidden", !isDark);
      };

      toggleButton.addEventListener("click", () => {
        const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        const nextTheme = currentTheme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = nextTheme;
        persistTheme(nextTheme);
        updateToggleState();
      });

      updateToggleState();
    })();
  </script>
</body>
</html>
