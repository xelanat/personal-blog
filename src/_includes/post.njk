---
layout: base.njk
---
<article>
  <header class="mb-8">
    <h1 class="text-3xl font-extrabold leading-tight mb-3 text-gray-900">{{ title }}</h1>
    <div class="flex items-center gap-4 flex-wrap text-gray-500 text-sm">
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | formatDate }}</time>
      {% if tags %}
      <ul class="flex flex-wrap gap-1.5 list-none">
        {% for tag in tags %}
          {% if tag !== "posts" %}
          <li>
            <a class="inline-block px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 text-xs font-medium hover:bg-blue-100 no-underline" href="/blog/?tag={{ tag | slugify }}">{{ tag }}</a>
          </li>
          {% endif %}
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </header>

  <div class="prose prose-gray max-w-none">
    {{ content | safe }}
  </div>

  <footer class="mt-12 pt-6 border-t border-gray-200">
    <a class="text-sm text-blue-600 hover:text-blue-700" href="/blog/">&larr; All posts</a>
  </footer>
</article>
